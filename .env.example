# ── WebShield Ortam Değişkenleri ──────────────────────────────────────────────
# Bu dosyayı asla Git'e yükleme! .gitignore'a ekli olduğundan emin ol.

# API Key doğrulamasını aç/kapat (true / false)
REQUIRE_AUTH=false

# Eğer REQUIRE_AUTH=true ise aşağıdaki key kullanılır.
# Güçlü ve rastgele bir değer girin (en az 32 karakter önerilir).
# Örnek üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
WEBSHIELD_API_KEY=buraya-guclu-bir-key-yazin

# Flask ortamı (development / production)
FLASK_ENV=production
